# Admin panel (set to "true" to enable)
ENABLE_ADMIN=true

# Bcrypt hash of your admin password
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Strong random secret for JWT signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Strong random secret for CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SECRET=

# Email notifications for contact form submissions
EMAIL_ADDRESS=       # the sending Gmail account
EMAIL_APP_PASSWORD=  # app password for the sending account
EMAIL_RECIPIENT=     # your main email where you want to receive notifications
